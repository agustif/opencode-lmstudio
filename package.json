{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-lmstudio",
  "version": "0.3.1",
  "description": "OpenCode plugin for enhanced LM Studio support with auto-detection, dynamic model discovery and LM Studio API key authentication",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "build": "tsc -p tsconfig.build.json",
    "validate": "npm run lint && npm run typecheck && npm run test:run",
    "validate:config": "bun scripts/validate-config.ts",
    "release": "bun scripts/release.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "lmstudio",
    "lm-studio",
    "plugin",
    "local-llm",
    "openai-compatible"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agustif/opencode-lmstudio.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.166"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
